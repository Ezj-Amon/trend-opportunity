# Comma-separated NewsNow source IDs.
TREND_SOURCES=weibo,zhihu,baidu,douyin,toutiao,bilibili-hot-search,coolapk,tieba,hackernews,producthunt,github-trending-today
NEWSNOW_BASE_URL=https://newsnow.busiyi.world
DATABASE_PATH=data/trends.db
ANALYSIS_TOP_N=5
OVERSEAS_ANALYSIS_TOP_N=5
GOOGLE_TRENDS_GEOS=US,GB,DE,JP
# 中国等来源发现的机会也必须绑定一个真实 Amazon 销售站点。
AMAZON_DEFAULT_MARKETPLACE=US
SCHEDULE_MINUTES=120
ENABLE_SCHEDULER=false

# Optional Reddit consumer discussion source. Uses Async PRAW + OAuth only.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendOpportunityLab/0.2 by your-reddit-name
REDDIT_SUBREDDITS=BuyItForLife,gadgets,HomeImprovement,shutupandtakemymoney

# Optional OpenAI-compatible model. Without these values the application uses
# the transparent local-rules-v1 baseline and labels it as such.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Optional Feishu custom bot. Secrets are never stored in SQLite.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Required before exposing the service beyond localhost. Browser users can set it with:
# localStorage.setItem('trendAdminToken', 'the-same-token')
ADMIN_TOKEN=
