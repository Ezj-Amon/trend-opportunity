# Comma-separated NewsNow source IDs.
TREND_SOURCES=weibo,zhihu,baidu,douyin,toutiao,bilibili-hot-search,coolapk,tieba,hackernews,producthunt,github-trending-today
NEWSNOW_BASE_URL=https://newsnow.busiyi.world
DATABASE_PATH=data/trends.db
RESEARCH_CANDIDATE_TOP_N=5
OVERSEAS_RESEARCH_CANDIDATE_TOP_N=5
GOOGLE_TRENDS_GEOS=US,GB,DE,JP
# 中国等来源发现的机会也必须绑定一个真实 Amazon 销售站点。
AMAZON_DEFAULT_MARKETPLACE=US
SCHEDULE_MINUTES=120
ENABLE_SCHEDULER=false

# Optional multilingual semantic baseline. Disabled by default and never downloads
# during normal tests. Install with `pip install -e .[ml]`, cache the model first,
# then enable it. Keep local-only true in production unless download is intentional.
ENABLE_EMBEDDINGS=false
EMBEDDING_MODEL_ID=intfloat/multilingual-e5-small
EMBEDDING_MODEL_REVISION=614241f622f53c4eeff9890bdc4f31cfecc418b3
EMBEDDING_CACHE_DIR=data/models
EMBEDDING_LOCAL_FILES_ONLY=true
SEMANTIC_FEATURE_VERSION=semantic-v1
SEMANTIC_DUPLICATE_THRESHOLD=0.90
SEMANTIC_DUPLICATE_WINDOW=500

# Evidence snapshots and bounded research orchestration. Pipeline and controlled
# tools stop after enough independent evidence; Agent and browser stay optional.
EVIDENCE_BUNDLE_VERSION=evidence-bundle-v2
EVIDENCE_READY_SCORE=1.8
RESEARCH_CANDIDATE_VERSION=research-candidate-v2
RESEARCH_MAX_SEARCH_QUERIES=1
RESEARCH_MAX_FETCH_PAGES=4
RESEARCH_TIMEOUT_SECONDS=300
# Default no-key independent-news discovery uses Google News RSS. Configure a
# private SearXNG instance to add a second search backend; public instances are
# intentionally not used.
ENABLE_PUBLIC_NEWS_SEARCH=true
PUBLIC_NEWS_MAX_RESULTS=4
SEARXNG_BASE_URL=
# Optional Reddit consumer discussion source. Uses Async PRAW + OAuth only.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=TrendOpportunityLab/0.2 by your-reddit-name
REDDIT_SUBREDDITS=BuyItForLife,gadgets,HomeImprovement,shutupandtakemymoney

# Optional OpenAI-compatible model for cloud OpportunityAssessment.
# Without these values the human research and assessment workflow remains available.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini

# Optional Feishu custom bot. Secrets are never stored in SQLite.
FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Required before exposing the service beyond localhost. Browser users can set it with:
# localStorage.setItem('trendAdminToken', 'the-same-token')
ADMIN_TOKEN=
